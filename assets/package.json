{
  "name": "mtaani",
  "version": "0.1.0",
  "description": "AI-powered responsible tourism platform for Kenya",
  "private": true,
  "scripts": {
    "build": "esbuild js/app.js --bundle --outdir=../priv/static/assets/js --loader:.js=js",
    "build:css": "tailwindcss --postcss --input=css/app.css --output=../priv/static/assets/css/app.css",
    "watch": "esbuild js/app.js --bundle --outdir=../priv/static/assets/js --loader:.js=js --watch",
    "watch:css": "tailwindcss --postcss --input=css/app.css --output=../priv/static/assets/css/app.css --watch"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "maplibre-gl": "^4.7.1",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}
